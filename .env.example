# GitHub personal access token (classic or fine-grained, public_repo read scope only).
# Used by scripts/fetch-github-stats.cjs at build time to populate
# githubStars / lastCommitDate / maintenanceStatus on alternatives.
# Without this, the build still succeeds but the Tool Finder Maintenance Activity
# dimension is hidden. Anonymous API limit is 60/hr, which is too low for ~80 repos.
#
# Create one at: https://github.com/settings/tokens
# Required scope: public_repo (read-only public repository metadata)
#
# Local development: copy this file to .env.local and fill in the value.
# Vercel: add GITHUB_TOKEN to Project Settings → Environment Variables.
GITHUB_TOKEN=

# Stock photo sources (Product 3 — Photos Finder)
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Buttondown email subscription (api/subscribe.ts)
# Used by api/subscribe.ts to forward email signups from EmailCapture.
# Without this, /api/subscribe returns 500.
# Get one at: https://buttondown.com/settings/programming
BUTTONDOWN_API_KEY=
