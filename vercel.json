{
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://aicalc.cloud/$1",
      "permanent": true,
      "has": [
        { "type": "host", "value": "prompt-cost-calculator-ten.vercel.app" }
      ]
    },
    {
      "source": "/(.*)",
      "destination": "https://aicalc.cloud/$1",
      "permanent": true,
      "has": [
        { "type": "host", "value": "codehelper.xyz" }
      ]
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/alternatives/:slug/", "destination": "/alternatives/:slug/index.html" },
    { "source": "/alternatives/:slug", "destination": "/alternatives/:slug/index.html" },
    { "source": "/cron-generator/:slug/", "destination": "/cron-generator/:slug/index.html" },
    { "source": "/cron-generator/:slug", "destination": "/cron-generator/:slug/index.html" },
    { "source": "/deploy/:slug/", "destination": "/deploy/:slug/index.html" },
    { "source": "/deploy/:slug", "destination": "/deploy/:slug/index.html" },
    { "source": "/compare/:slug/", "destination": "/compare/:slug/index.html" },
    { "source": "/compare/:slug", "destination": "/compare/:slug/index.html" },
    { "source": "/mcp-servers/:slug/", "destination": "/mcp-servers/:slug/index.html" },
    { "source": "/mcp-servers/:slug", "destination": "/mcp-servers/:slug/index.html" },
    { "source": "/ai-code-review/:slug/", "destination": "/ai-code-review/:slug/index.html" },
    { "source": "/ai-code-review/:slug", "destination": "/ai-code-review/:slug/index.html" },
    { "source": "/finder/:slug/", "destination": "/finder/:slug/index.html" },
    { "source": "/finder/:slug", "destination": "/finder/:slug/index.html" },
    { "source": "/llm-pricing/:slug/", "destination": "/llm-pricing/:slug/index.html" },
    { "source": "/llm-pricing/:slug", "destination": "/llm-pricing/:slug/index.html" },
    { "source": "/token-tracker/:slug/", "destination": "/token-tracker/:slug/index.html" },
    { "source": "/token-tracker/:slug", "destination": "/token-tracker/:slug/index.html" },
    { "source": "/prompt-cache-calculator/:slug/", "destination": "/prompt-cache-calculator/:slug/index.html" },
    { "source": "/prompt-cache-calculator/:slug", "destination": "/prompt-cache-calculator/:slug/index.html" },
    { "source": "/voice-agent-pricing/:slug/", "destination": "/voice-agent-pricing/:slug/index.html" },
    { "source": "/voice-agent-pricing/:slug", "destination": "/voice-agent-pricing/:slug/index.html" },
    { "source": "/csp-generator/:slug/", "destination": "/csp-generator/:slug/index.html" },
    { "source": "/csp-generator/:slug", "destination": "/csp-generator/:slug/index.html" },
    { "source": "/pii-redactor/:slug/", "destination": "/pii-redactor/:slug/index.html" },
    { "source": "/pii-redactor/:slug", "destination": "/pii-redactor/:slug/index.html" },
    { "source": "/photos/:slug/", "destination": "/photos/:slug/index.html" },
    { "source": "/photos/:slug", "destination": "/photos/:slug/index.html" }
  ]
}
